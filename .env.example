# Vite exposes only variables prefixed with VITE_ or NEXT_PUBLIC_ (see vite.config.ts).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: same keys using Next-style names (supported for convenience)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
